# ─────────────────────────────────────────────────────────────
# NYC Taxi Demand MLOps — Environment Variables
# Copy this to .env and fill in all values marked <CHANGE_ME>
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=taxi
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=taxi_demand
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=<CHANGE_ME>
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=<CHANGE_ME>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=<CHANGE_ME>
AIRFLOW_UID=50000

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
# For local dev without S3, artifacts go to /mlflow/artifacts volume
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
# For production (S3):
# MLFLOW_ARTIFACT_ROOT=s3://${S3_BUCKET_NAME}/mlflow-artifacts

# ── DagsHub (MLflow from Colab / remote) ─────────────────────
# Get token from: https://dagshub.com/user/settings/tokens
DAGSHUB_USER=<CHANGE_ME>
DAGSHUB_TOKEN=<CHANGE_ME>
DAGSHUB_MLFLOW_URI=https://dagshub.com/<CHANGE_ME>/nyc-taxi-demand-mlops.mlflow

# ── AWS ──────────────────────────────────────────────────────
# Create IAM user with S3FullAccess + EC2FullAccess
AWS_ACCESS_KEY_ID=<CHANGE_ME>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=nyc-taxi-demand-mlops

# ── Redis (Feast online store) ────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ── Slack ────────────────────────────────────────────────────
# Get from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<CHANGE_ME>
SLACK_CHANNEL=#taxi-demand-alerts

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501

# ── Data ─────────────────────────────────────────────────────
NYC_TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
NYC_TAXI_ZONES_URL=https://d37ci6vzurychx.cloudfront.net/misc/taxi_zones.zip
# How many months of history to backfill on first run
BACKFILL_MONTHS=24
